<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>طلب تعديل - <%= purchase.projectTitle %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="auth-page">
    <div class="container">
      <div class="auth-box">
        <h2>طلب تعديل على المشروع</h2>
        <p class="project-name"><%= purchase.projectTitle %></p>
        
        <% if (error) { %>
          <div class="error-message"><%= error %></div>
        <% } %>
        
        <form action="/request-modification/<%= purchase.id %>" method="POST">
          <div class="form-group">
            <label for="description">وصف التعديل المطلوب *</label>
            <textarea id="description" name="description" rows="6" placeholder="اكتب التعديلات التي تريدها بالتفصيل... مثال: أريد تغيير الألوان، إضافة صفحة جديدة، تعديل اللوجو..." required></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary btn-full">إرسال الطلب</button>
        </form>
        
        <p class="auth-link"><a href="/my-purchases">← العودة لمشترياتي</a></p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
