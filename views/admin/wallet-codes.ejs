<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>أكواد الشحن - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <a href="/admin/projects/new">إضافة مشروع</a>
        <a href="/admin/purchases">المشتريات</a>
        <a href="/admin/modifications">طلبات التعديل</a>
        <a href="/admin/messages">الرسائل</a>
        <a href="/admin/reviews">التقييمات</a>
        <a href="/admin/coupons">الكوبونات</a>
        <a href="/admin/referrals">الإحالات</a>
        <a href="/admin/wallet-codes" class="active">أكواد الشحن</a>
        <a href="/admin/wallet-balances">أرصدة العملاء</a>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <a href="/admin/users">المستخدمين</a>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <h1>أكواد شحن الرصيد</h1>

      <section class="admin-section">
        <div class="section-header">
          <h2>إضافة كود شحن</h2>
        </div>

        <% if (error) { %>
          <div class="error-message"><%= error %></div>
        <% } %>

        <div class="form-container">
          <form action="/admin/wallet-codes" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="code">الكود</label>
                <input id="code" name="code" type="text" placeholder="مثال: TOPUP100" required>
              </div>
              <div class="form-group">
                <label for="amount">قيمة الرصيد</label>
                <input id="amount" name="amount" type="number" step="0.01" min="0" required>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="expiresAt">تاريخ الانتهاء (اختياري)</label>
                <input id="expiresAt" name="expiresAt" type="date">
              </div>
              <div class="form-group">
                <label for="usageLimit">عدد مرات الاستخدام (اختياري)</label>
                <input id="usageLimit" name="usageLimit" type="number" min="1" step="1">
              </div>
            </div>

            <button type="submit" class="btn btn-primary">إضافة</button>
          </form>
        </div>
      </section>

      <section class="admin-section" style="margin-top: 26px;">
        <div class="section-header">
          <h2>الأكواد الحالية</h2>
        </div>

        <% if (!walletCodes || walletCodes.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">💳</div>
            <h2>لا توجد أكواد بعد</h2>
            <p>قم بإنشاء أكواد شحن لإضافة رصيد للمستخدمين.</p>
          </div>
        <% } else { %>
          <div class="table-container">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>الكود</th>
                  <th>الرصيد</th>
                  <th>الحالة</th>
                  <th>الاستخدام</th>
                  <th>الانتهاء</th>
                  <th>الإجراءات</th>
                </tr>
              </thead>
              <tbody>
                <% walletCodes.slice().reverse().forEach(c => { %>
                  <tr>
                    <td><%= c.code %></td>
                    <td><%= Number(c.amount || 0) %> ج</td>
                    <td>
                      <% if (c.active) { %>
                        <span class="status-badge approved">✓ فعّال</span>
                      <% } else { %>
                        <span class="status-badge rejected">✗ غير فعّال</span>
                      <% } %>
                    </td>
                    <td>
                      <%= Number(c.usedCount || 0) %>
                      /
                      <%= c.usageLimit == null ? '∞' : Number(c.usageLimit || 0) %>
                    </td>
                    <td><%= c.expiresAt ? new Date(c.expiresAt).toLocaleDateString('ar-EG') : '-' %></td>
                    <td>
                      <form action="/admin/wallet-codes/<%= c.id %>/toggle" method="POST" style="display:inline-block;">
                        <button type="submit" class="btn btn-secondary"><%= c.active ? 'إيقاف' : 'تفعيل' %></button>
                      </form>
                      <form action="/admin/wallet-codes/<%= c.id %>/delete" method="POST" style="display:inline-block;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('هل أنت متأكد من الحذف؟')">حذف</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
