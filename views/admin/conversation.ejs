<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>محادثة مع <%= chatUser ? chatUser.name : 'مستخدم' %> - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/messages.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <a href="/admin/projects/new">إضافة مشروع</a>
        <a href="/admin/purchases">المشتريات</a>
        <a href="/admin/modifications">طلبات التعديل</a>
        <a href="/admin/messages" class="active">الرسائل</a>
        <a href="/admin/reviews">التقييمات</a>
        <a href="/admin/coupons">الكوبونات</a>
        <a href="/admin/referrals">الإحالات</a>
        <a href="/admin/wallet-codes">أكواد الشحن</a>
        <a href="/admin/wallet-balances">أرصدة العملاء</a>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <a href="/admin/users">المستخدمين</a>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <div class="chat-container">
        <div class="chat-header">
          <a href="/admin/messages" class="back-link">← العودة للرسائل</a>
          <h2>💬 <%= chatUser ? chatUser.name : 'مستخدم غير معروف' %></h2>
          <p><%= chatUser ? chatUser.email : '' %></p>
        </div>

        <div class="chat-messages admin-chat">
          <% if (messages.length === 0) { %>
            <div class="empty-chat">
              <p>لا توجد رسائل</p>
            </div>
          <% } else { %>
            <% messages.forEach(msg => { %>
              <div class="message <%= msg.senderId === 'admin' ? 'sent' : 'received' %>">
                <div class="message-content">
                  <%= msg.content %>
                </div>
                <div class="message-meta">
                  <span class="sender"><%= msg.senderId === 'admin' ? 'أنت' : (chatUser ? chatUser.name : 'المستخدم') %></span>
                  <span class="time"><%= new Date(msg.createdAt).toLocaleString('ar-EG', { hour: '2-digit', minute: '2-digit', day: 'numeric', month: 'short' }) %></span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <div class="chat-input">
          <form action="/admin/messages/<%= chatUser ? chatUser.id : '' %>" method="POST" class="message-form">
            <textarea name="content" placeholder="اكتب ردك هنا..." required rows="3"></textarea>
            <button type="submit" class="btn btn-primary">إرسال</button>
          </form>
        </div>
      </div>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
