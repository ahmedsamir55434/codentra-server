<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>المواعيد - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.projects))) { %>
          <a href="/admin/projects/new">إضافة مشروع</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.purchases))) { %>
          <a href="/admin/purchases">المشتريات</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.modifications))) { %>
          <a href="/admin/modifications">طلبات التعديل</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.messages))) { %>
          <a href="/admin/messages">الرسائل</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.reviews))) { %>
          <a href="/admin/reviews">التقييمات</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.coupons))) { %>
          <a href="/admin/coupons">الكوبونات</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.referrals))) { %>
          <a href="/admin/referrals">الإحالات</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.walletCodes))) { %>
          <a href="/admin/wallet-codes">أكواد الشحن</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.walletBalances))) { %>
          <a href="/admin/wallet-balances">أرصدة العملاء</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.appointments))) { %>
          <a href="/admin/appointments" class="active">المواعيد</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.subscriptionCoupons))) { %>
          <a href="/admin/subscription-coupons">كوبونات الاشتراك</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.subscriptionPlans))) { %>
          <a href="/admin/subscription-plans">خطط الاشتراك</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.subscriptionReports))) { %>
          <a href="/admin/subscription-reports">تقارير الاشتراك</a>
        <% } %>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/meeting-recordings">تسجيلات الاجتماعات</a>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <% if (user && (user.isSuperAdmin || (user.adminPermissions && user.adminPermissions.users))) { %>
          <a href="/admin/users">المستخدمين</a>
        <% } %>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <h1>المواعيد</h1>

      <% if (error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="success-message"><%= success %></div>
      <% } %>

      <section class="admin-section">
        <div class="section-header">
          <h2>إضافة موعد فاضي</h2>
        </div>

        <div class="form-container">
          <form action="/admin/appointments/slots" method="POST" class="admin-form">
            <div class="form-row">
              <div class="form-group">
                <label for="date">التاريخ *</label>
                <input type="date" id="date" name="date" required>
              </div>
              <div class="form-group">
                <label for="time">الوقت *</label>
                <input type="time" id="time" name="time" required>
              </div>
            </div>
            <div class="form-group">
              <label for="durationMinutes">المدة بالدقائق *</label>
              <input type="number" id="durationMinutes" name="durationMinutes" min="15" max="240" value="30" required>
            </div>
            <button type="submit" class="btn btn-primary">إضافة</button>
          </form>
        </div>
      </section>

      <section class="admin-section" style="margin-top:20px;">
        <div class="section-header">
          <h2>مواعيدي المتاحة</h2>
        </div>

        <% if (!slots || slots.length === 0) { %>
          <div class="empty-state" style="margin-top:10px;">
            <div class="empty-icon">📅</div>
            <h2>لا يوجد مواعيد</h2>
            <p>أضف مواعيد فاضية ليتمكن العملاء من الحجز</p>
          </div>
        <% } else { %>
          <div class="table-container">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>الوقت</th>
                  <th>المدة</th>
                  <th>الحالة</th>
                  <th>إجراء</th>
                </tr>
              </thead>
              <tbody>
                <% slots.forEach(s => { %>
                  <tr>
                    <td><%= s.label %></td>
                    <td><%= Number(s.durationMinutes || 30) %> دقيقة</td>
                    <td>
                      <% if (s.status === 'available') { %>
                        <span class="status-badge approved">متاح</span>
                      <% } else { %>
                        <span class="status-badge pending">محجوز</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (s.status === 'available') { %>
                        <form action="/admin/appointments/slots/<%= s.id %>/delete" method="POST" style="display:inline;">
                          <button type="submit" class="btn btn-secondary">حذف</button>
                        </form>
                      <% } else { %>
                        <span class="waiting-text">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

      <section class="admin-section" style="margin-top:20px;">
        <div class="section-header">
          <h2>الحجوزات</h2>
        </div>

        <% if (!bookings || bookings.length === 0) { %>
          <div class="empty-state" style="margin-top:10px;">
            <div class="empty-icon">💬</div>
            <h2>لا يوجد حجوزات</h2>
            <p>سيظهر هنا أي حجز يقوم به عميل</p>
          </div>
        <% } else { %>
          <div class="table-container">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>العميل</th>
                  <th>الوقت</th>
                  <th>المدة</th>
                  <th>الرابط</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach(b => { %>
                  <tr>
                    <td><%= b.userName || b.userId %></td>
                    <td><%= b.startAt ? new Date(b.startAt).toLocaleString('ar-EG') : '' %></td>
                    <td><%= Number(b.durationMinutes || 30) %> دقيقة</td>
                    <td>
                      <% if (b.meetingLink) { %>
                        <a href="<%= b.meetingLink %>" target="_blank" rel="noopener">فتح الاجتماع</a>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
