<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>أرصدة العملاء - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <a href="/admin/projects/new">إضافة مشروع</a>
        <a href="/admin/purchases">المشتريات</a>
        <a href="/admin/modifications">طلبات التعديل</a>
        <a href="/admin/messages">الرسائل</a>
        <a href="/admin/reviews">التقييمات</a>
        <a href="/admin/coupons">الكوبونات</a>
        <a href="/admin/referrals">الإحالات</a>
        <a href="/admin/wallet-codes">أكواد الشحن</a>
        <a href="/admin/wallet-balances" class="active">أرصدة العملاء</a>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <a href="/admin/users">المستخدمين</a>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <h1>أرصدة العملاء</h1>

      <% if (error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="success-message"><%= success %></div>
      <% } %>

      <div class="table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>الاسم</th>
              <th>البريد</th>
              <th>الرصيد</th>
              <th>تعديل الرصيد</th>
            </tr>
          </thead>
          <tbody>
            <% users.filter(u => u.role === 'user').forEach(u => { %>
              <tr>
                <td><%= u.name %></td>
                <td><%= u.email %></td>
                <td><strong><%= Number(u.walletBalance || 0) %></strong> ج</td>
                <td>
                  <form action="/admin/wallet-balances/<%= u.id %>" method="POST" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                    <select name="action" required>
                      <option value="add">زيادة</option>
                      <option value="subtract">خصم</option>
                      <option value="set">تعيين</option>
                    </select>
                    <input name="amount" type="number" step="0.01" min="0" placeholder="المبلغ" required style="max-width:160px;">
                    <button type="submit" class="btn btn-primary">تطبيق</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
