<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>الكوبونات - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <a href="/admin/projects/new">إضافة مشروع</a>
        <a href="/admin/purchases">المشتريات</a>
        <a href="/admin/modifications">طلبات التعديل</a>
        <a href="/admin/messages">الرسائل</a>
        <a href="/admin/reviews">التقييمات</a>
        <a href="/admin/coupons" class="active">الكوبونات</a>
        <a href="/admin/referrals">الإحالات</a>
        <a href="/admin/wallet-codes">أكواد الشحن</a>
        <a href="/admin/wallet-balances">أرصدة العملاء</a>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <a href="/admin/users">المستخدمين</a>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <h1>الكوبونات</h1>

      <section class="admin-section">
        <div class="section-header">
          <h2>إضافة كوبون</h2>
        </div>

        <% if (error) { %>
          <div class="error-message"><%= error %></div>
        <% } %>

        <div class="form-container">
          <form action="/admin/coupons" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="code">كود الكوبون</label>
                <input id="code" name="code" type="text" placeholder="مثال: SAVE10" required>
              </div>
              <div class="form-group">
                <label for="type">النوع</label>
                <select id="type" name="type" required>
                  <option value="percent">نسبة %</option>
                  <option value="fixed">خصم ثابت</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="value">القيمة</label>
                <input id="value" name="value" type="number" step="0.01" min="0" required>
              </div>
              <div class="form-group">
                <label for="expiresAt">تاريخ الانتهاء (اختياري)</label>
                <input id="expiresAt" name="expiresAt" type="date">
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="usageLimit">عدد مرات الاستخدام (اختياري)</label>
                <input id="usageLimit" name="usageLimit" type="number" min="1" step="1">
              </div>
            </div>

            <button type="submit" class="btn btn-primary">إضافة</button>
          </form>
        </div>
      </section>

      <section class="admin-section" style="margin-top: 26px;">
        <div class="section-header">
          <h2>كل الكوبونات</h2>
        </div>

        <% if (!coupons || coupons.length === 0) { %>
          <div class="empty-state">
            <p>لا توجد كوبونات بعد</p>
          </div>
        <% } else { %>
          <div class="admin-table-container">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>الكود</th>
                  <th>النوع</th>
                  <th>القيمة</th>
                  <th>الحالة</th>
                  <th>الاستخدام</th>
                  <th>الانتهاء</th>
                  <th>إجراءات</th>
                </tr>
              </thead>
              <tbody>
                <% coupons.forEach(c => { %>
                  <tr>
                    <td><strong><%= c.code %></strong></td>
                    <td><%= c.type === 'fixed' ? 'ثابت' : 'نسبة' %></td>
                    <td>
                      <% if (c.type === 'fixed') { %>
                        <%= c.value %> ج
                      <% } else { %>
                        <%= c.value %> %
                      <% } %>
                    </td>
                    <td>
                      <% if (c.active) { %>
                        <span class="status-badge approved">فعّال</span>
                      <% } else { %>
                        <span class="status-badge rejected">متوقف</span>
                      <% } %>
                    </td>
                    <td>
                      <%= (c.usedCount || 0) %>
                      <% if (c.usageLimit) { %>
                        / <%= c.usageLimit %>
                      <% } %>
                    </td>
                    <td>
                      <%= c.expiresAt ? new Date(c.expiresAt).toLocaleDateString('ar-EG') : '-' %>
                    </td>
                    <td class="actions">
                      <form action="/admin/coupons/<%= c.id %>/toggle" method="POST" class="inline-form">
                        <button type="submit" class="btn btn-sm btn-secondary"><%= c.active ? 'إيقاف' : 'تفعيل' %></button>
                      </form>
                      <form action="/admin/coupons/<%= c.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('هل أنت متأكد من حذف الكوبون؟')">
                        <button type="submit" class="btn btn-sm btn-danger">حذف</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
