<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>خطط الاشتراك - Codentra</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="admin-layout">
    <aside class="admin-sidebar">
      <nav class="admin-nav">
        <a href="/admin">الرئيسية</a>
        <a href="/admin/projects/new">إضافة مشروع</a>
        <a href="/admin/purchases">المشتريات</a>
        <a href="/admin/modifications">طلبات التعديل</a>
        <a href="/admin/messages">الرسائل</a>
        <a href="/admin/reviews">التقييمات</a>
        <a href="/admin/coupons">كوبونات المشاريع</a>
        <a href="/admin/subscription-coupons">كوبونات الاشتراكات</a>
        <a href="/admin/subscription-reports">تقارير الاشتراكات</a>
        <a href="/admin/subscription-plans" class="active">خطط الاشتراك</a>
        <a href="/admin/referrals">الإحالات</a>
        <a href="/admin/wallet-codes">أكواد الشحن</a>
        <a href="/admin/wallet-balances">أرصدة العملاء</a>
        <a href="/admin/appointments">المواعيد</a>
        <% if (user && user.isSuperAdmin) { %>
          <a href="/admin/meeting-recordings">تسجيلات الاجتماعات</a>
          <a href="/admin/admins">إدارة الأدمنز</a>
        <% } %>
        <a href="/admin/users">المستخدمين</a>
        <a href="/">العودة للموقع</a>
      </nav>
    </aside>

    <main class="admin-content">
      <h1>خطط الاشتراك</h1>

      <% if (error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="success-message"><%= success %></div>
      <% } %>

      <section class="admin-section" style="margin-top: 16px;">
        <div class="section-header">
          <h2>كل الخطط</h2>
        </div>

        <% if (!plans || plans.length === 0) { %>
          <div class="empty-state">
            <p>لا توجد خطط</p>
          </div>
        <% } else { %>
          <div class="admin-table-container">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>الخطة</th>
                  <th>السعر</th>
                  <th>المدة</th>
                  <th>الحالة</th>
                  <th>إجراءات</th>
                </tr>
              </thead>
              <tbody>
                <% plans.forEach(p => { %>
                  <tr>
                    <td><strong><%= p.name %></strong> <span style="opacity:.7">(<%= p.id %>)</span></td>
                    <td><%= p.price %> <%= p.currency || 'EGP' %></td>
                    <td><%= p.durationDays %> يوم</td>
                    <td>
                      <% if (p.active) { %>
                        <span class="status-badge approved">فعّال</span>
                      <% } else { %>
                        <span class="status-badge rejected">متوقف</span>
                      <% } %>
                    </td>
                    <td class="actions">
                      <form action="/admin/subscription-plans/<%= p.id %>/toggle" method="POST" class="inline-form">
                        <button type="submit" class="btn btn-sm btn-secondary"><%= p.active ? 'إيقاف' : 'تفعيل' %></button>
                      </form>
                    </td>
                  </tr>
                  <tr>
                    <td colspan="5">
                      <form action="/admin/subscription-plans/<%= p.id %>" method="POST" style="display:flex; flex-wrap:wrap; gap:12px; align-items:end;">
                        <div class="form-group" style="min-width: 180px;">
                          <label>الاسم</label>
                          <input name="name" type="text" value="<%= p.name %>" required>
                        </div>
                        <div class="form-group" style="min-width: 160px;">
                          <label>السعر</label>
                          <input name="price" type="number" step="0.01" min="0" value="<%= p.price %>" required>
                        </div>
                        <div class="form-group" style="min-width: 160px;">
                          <label>المدة بالأيام</label>
                          <input name="durationDays" type="number" step="1" min="1" value="<%= p.durationDays %>" required>
                        </div>
                        <div class="form-group" style="min-width: 160px;">
                          <label>العملة</label>
                          <input name="currency" type="text" value="<%= p.currency || 'EGP' %>" required>
                        </div>
                        <div class="form-group" style="min-width: 220px; flex:1;">
                          <label>المزايا (سطر لكل ميزة)</label>
                          <textarea name="features" rows="3" style="width:100%;"><%= Array.isArray(p.features) ? p.features.join('\n') : '' %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">حفظ</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
