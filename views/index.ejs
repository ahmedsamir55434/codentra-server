<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Codentra - مشاريع برمجية جاهزة</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <% const safeRecentProjects = Array.isArray(recentProjects) ? recentProjects : []; %>

  <main class="hero">
    <div class="container">
      <h1>مشاريع برمجية احترافية جاهزة</h1>
      <p>اشترِ مشاريع ويب وتطبيقات كاملة مع الكود المصدر فورًا</p>
    </div>
  </main>

  <% if (safeRecentProjects.length > 0) { %>
    <section class="projects-section recently-viewed-section">
      <div class="container">
        <div class="section-head">
          <div>
            <span class="section-kicker">متابعة سريعة</span>
            <h2>شوهد مؤخرًا</h2>
          </div>
          <p class="section-copy">ارجع بسرعة لآخر المشاريع التي فتحتها وكمل من حيث توقفت.</p>
        </div>

        <div class="projects-grid recent-projects-grid">
          <% safeRecentProjects.forEach(project => { %>
            <div class="project-card project-card-recent">
              <div class="project-image <%= project.images && project.images.length > 0 ? 'has-cover' : '' %>">
                <% if (project.images && project.images.length > 0) { %>
                  <img src="/<%= project.images[0] %>" alt="<%= project.title %>" class="project-cover">
                <% } else { %>
                  <div class="placeholder-img">
                    <span><%= project.category %></span>
                  </div>
                <% } %>
              </div>
              <div class="project-info">
                <span class="project-card-eyebrow">آخر زيارة</span>
                <h3><%= project.title %></h3>
                <p class="project-desc"><%= project.description.substring(0, 100) %><%= project.description.length > 100 ? '...' : '' %></p>
                <div class="project-tech">
                  <% project.technologies.slice(0, 3).forEach(tech => { %>
                    <span class="tech-tag"><%= tech %></span>
                  <% }) %>
                </div>
                <div class="project-footer">
                  <span class="price"><%= project.price %> جنيه</span>
                  <a href="/project/<%= project.id %>" class="btn btn-secondary">متابعة</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

  <section class="projects-section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="section-kicker">السوق</span>
          <h2>المشاريع المتاحة</h2>
        </div>
        <p class="section-copy">تصفح كل المشاريع الجاهزة واختر المشروع الأنسب لاحتياجك الحالي.</p>
      </div>
      <div class="projects-grid">
        <% projects.forEach(project => { %>
          <div class="project-card">
            <div class="project-image <%= project.images && project.images.length > 0 ? 'has-cover' : '' %>">
              <% if (project.images && project.images.length > 0) { %>
                <img src="/<%= project.images[0] %>" alt="<%= project.title %>" class="project-cover">
              <% } else { %>
                <div class="placeholder-img">
                  <span><%= project.category %></span>
                </div>
              <% } %>
            </div>
            <div class="project-info">
              <h3><%= project.title %></h3>
              <p class="project-desc"><%= project.description.substring(0, 100) %><%= project.description.length > 100 ? '...' : '' %></p>
              <div class="project-tech">
                <% project.technologies.slice(0, 3).forEach(tech => { %>
                  <span class="tech-tag"><%= tech %></span>
                <% }) %>
              </div>
              <div class="project-footer">
                <span class="price"><%= project.price %> جنيه</span>
                <a href="/project/<%= project.id %>" class="btn btn-primary">تفاصيل</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      
      <% if (projects.length === 0) { %>
        <div class="empty-state">
          <p>لا توجد مشاريع متاحة حاليًا</p>
        </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
